{
  "name": "skillget",
  "version": "1.0.0",
  "description": "ClawHub skills and plugins scout with GitHub Pages publishing",
  "private": true,
  "main": "scripts/scrape-clawhub.ts",
  "scripts": {
    "dev": "vite",
    "build": "npm run scrape && vite build",
    "preview": "vite preview",
    "scrape": "node --import tsx scripts/scrape-clawhub.ts",
    "build:source-optimized": "node scripts/build-source-optimized-packages.mjs",
    "package:source-optimized": "node scripts/package-source-optimized.mjs",
    "verify:source-optimized": "node scripts/verify-source-optimized.mjs",
    "live-test:source-optimized": "node scripts/live-test-source-optimized.mjs",
    "publish:optimized-downloads": "node scripts/publish-optimized-downloads.mjs",
    "download:suspicious-zips": "node scripts/download-suspicious-zips.mjs",
    "typecheck": "tsc --noEmit",
    "deploy:server": "bash deploy/deploy-server.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "cli-progress": "^3.12.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^7.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
